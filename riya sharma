
# --- Load Required Libraries ---
# recommenderlab: Main package for recommendation algorithms
# ggplot2: For data visualization
# data.table: For efficient data manipulation
library(recommenderlab)
library(ggplot2)
library(data.table)

# --- Load Dataset ---
# We use the built-in MovieLense dataset
data("MovieLense")

# --- Data Exploration ---
# Visualizing the distribution of ratings
vector_ratings <- as.vector(MovieLense@data)
vector_ratings <- vector_ratings[vector_ratings != 0] # Remove zero/unrated entries

qplot(vector_ratings, fill=I("steelblue"), col=I("red"), 
      main="Distribution of Ratings", xlab="Rating")




# --- Visualization: Rating Density ---
# This shows how many ratings exist vs. how many are missing
library(ggplot2)

sparse_data <- data.frame(
  Status = c("Rated", "Unrated"),
  Count = c(nratings(MovieLense), 
            (nrow(MovieLense) * ncol(MovieLense)) - nratings(MovieLense))
)

ggplot(sparse_data, aes(x = "", y = Count, fill = Status)) +
  geom_bar(stat = "identity", width = 1) +
  coord_polar("y", start = 0) +
  theme_void() +
  scale_fill_manual(values = c("#2ecc71", "#ecf0f1")) +
  labs(title = "Data Sparsity: Rated vs. Unrated Movies")




# --- Load Lattice for levelplot ---
library(lattice)

# 1. Identify the top 10 most rated movies
top_indices <- order(colCounts(MovieLense), decreasing = TRUE)[1:10]

# 2. Get the titles for these movies (using the colnames of the S4 object)
top_titles <- colnames(MovieLense)[top_indices]

# 3. Correct S4 Coercion: Convert only the subset to a standard matrix
subset_matrix <- as(MovieLense[, top_indices], "matrix")

# 4. Calculate Correlation
# 'pairwise.complete.obs' handles the missing (NA) values between movie pairs
cor_matrix <- cor(subset_matrix, use = "pairwise.complete.obs")

# 5. Set the row and column names so the plot shows movie titles
rownames(cor_matrix) <- top_titles
colnames(cor_matrix) <- top_titles

# 6. Plotting
levelplot(cor_matrix, 
          scales = list(x = list(rot = 90)), # Rotate movie titles for readability
          main = "Correlation Heatmap: Top 10 Movies",
          col.regions = rev(heat.colors(100)), # Using a heat scale
          xlab = "", ylab = "")





# --- Similarity Visualization ---
# Calculate similarity between the first 10 movies
similarity_movies <- similarity(MovieLense[, 1:10], 
                                method = "cosine", 
                                which = "items")

# Convert to matrix and plot
image(as.matrix(similarity_movies), 
      main = "Item Similarity (Cosine)",
      col = grey.colors(100))





