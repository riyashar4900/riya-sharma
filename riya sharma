# --- 3. THE LOGIC (SERVER) ---
server <- function(input, output, session) {
  
  # Reactive prevention of duplicate selections
  observe({
    selected_vals <- c(input$movie_1, input$movie_2, input$movie_3, input$movie_4, input$movie_5)
    for(i in 1:5) {
      current_val <- input[[paste0("movie_", i)]]
      others_selected <- selected_vals[-i]
      remaining_choices <- setdiff(all_movie_names, others_selected)
      updatePickerInput(session, paste0("movie_", i), choices = remaining_choices, selected = current_val)
    }
  })
  
  recom_results <- eventReactive(input$btn_recommend, {
    user_ratings <- matrix(0, nrow = 1, ncol = ncol(movie_data))
    colnames(user_ratings) <- colnames(movie_data)
    
    rating_sum <- 0 
    user_selected <- c()
    for(i in 1:5) {
      m <- input[[paste0("movie_", i)]]; r <- input[[paste0("rate_", i)]]
      user_ratings[1, m] <- r
      user_selected <- c(user_selected, m)
      rating_sum <- rating_sum + (r * i) 
    }
    
    set.seed(round(rating_sum * 100)) 
    user_matrix <- as(user_ratings, "realRatingMatrix")
    
    # Model Execution
    rec_model <- Recommender(movie_data, method = "UBCF")
    pred <- predict(rec_model, user_matrix, n = 20) 
    cf_recoms <- as(pred, "list")[[1]]
    unique_recoms <- setdiff(cf_recoms, user_selected)
    
    if(length(unique_recoms) >= 5) {
      final <- sample(head(unique_recoms, 15), 5)
    } else {
      needed <- 5 - length(unique_recoms)
      fallback <- setdiff(popular_movies, c(user_selected, unique_recoms))
      final <- c(unique_recoms, sample(head(fallback, 30), needed))
    }
    return(final)
  })
  
  # Beautiful Results Rendering (No more boring tables!)
  output$movie_results <- renderUI({
    req(recom_results())
    movies <- recom_results()
    
    tagList(
      lapply(1:5, function(i) {
        div(class = "movie-card",
            div(class = "rank-circle", i),
            span(movies[i], style="font-size: 1.3rem; font-weight: 700; color: #fff;")
        )
      })
    )
  })
}

shinyApp(ui, server)
